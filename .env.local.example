# -------------------------------------------------------------------------
# Supabase — https://app.supabase.com/project/<your-project>/settings/api
# -------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# -------------------------------------------------------------------------
# Resend — https://resend.com/api-keys
# -------------------------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
# "From" address — must be a domain verified in your Resend account.
# During development you can use: Scripture Summer <onboarding@resend.dev>
RESEND_FROM_EMAIL=Scripture Summer <onboarding@resend.dev>

# -------------------------------------------------------------------------
# App URL — used in email links (no trailing slash)
# -------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -------------------------------------------------------------------------
# Supabase service role key — server-only, never expose to the browser.
# Found at: https://app.supabase.com/project/<your-project>/settings/api
# -------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# -------------------------------------------------------------------------
# Anthropic — https://console.anthropic.com/settings/keys
# Used by the daily reminder cron to generate encouragement messages.
# -------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# -------------------------------------------------------------------------
# Cron secret — protects /api/cron/send-reminders from unauthorized calls.
# Set this in your Vercel project settings (Environment Variables).
# Vercel automatically sends it as: Authorization: Bearer <CRON_SECRET>
# Generate one with: openssl rand -hex 32
# -------------------------------------------------------------------------
CRON_SECRET=your-cron-secret
